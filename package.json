{
  "name": "ws-design-server",
  "version": "1.0.0",
  "description": "中盈BPM管理系统 - 后端服务",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:dev": "ts-node --no-cache src/main.ts",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "format": "prettier --write 'src/**/*.{js,ts,vue}'",
    "#format": "代码格式化"
  },
  "dependencies": {
    "@nestjs/common": "^9.4.0",
    "@nestjs/core": "^9.4.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^9.0.3",
    "@nestjs/platform-express": "^9.4.0",
    "@prisma/client": "^5.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.4.0",
    "@nestjs/schematics": "^9.1.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.0",
    "@types/passport-jwt": "^3.0.8",
    "prettier": "^3.9.4",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.0"
  }
}
